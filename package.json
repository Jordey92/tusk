{
  "name": "@bydey/tusk",
  "version": "0.2.0",
  "description": "SQL-first PostgreSQL migrations for Node.js and Bun",
  "author": "Bydey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordey92/tusk.git"
  },
  "homepage": "https://github.com/jordey92/tusk#readme",
  "bugs": {
    "url": "https://github.com/jordey92/tusk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "migration",
    "migrations",
    "database",
    "sql",
    "sql-first",
    "elysia",
    "bun",
    "node"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "tusk": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun run test:unit",
    "test:unit": "bun test core/create-migration.test.ts core/read-migrations.test.ts core/rollback-plan.test.ts utils/checksum.test.ts utils/errors.test.ts utils/filename.test.ts utils/logger.test.ts utils/runtime.test.ts utils/version.test.ts adapters/pg/sql-generator.test.ts adapters/pg/introspection.test.ts adapters/pg/locking.test.ts",
    "test:smoke:package": "bun test package-smoke.test.ts",
    "test:smoke": "TUSK_SMOKE_DATABASE_URL=postgresql://user:password@127.0.0.1:5433/migrate_tool_test bun test package-smoke.test.ts cli.test.ts plugins/elysia.test.ts",
    "test:db": "bun test adapters/pg.test.ts adapters/postgresjs.test.ts core/run-migrations.test.ts core/init-migration.test.ts core/track-migrations.test.ts",
    "test:ci": "bun run build && TUSK_PACKAGE_SMOKE_SKIP_BUILD=1 bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.6.2",
    "@types/pg": "^8.15.5",
    "elysia": "^1.4.9",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "postgres": ">=3.0.0",
    "elysia": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "elysia": {
      "optional": true
    }
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
