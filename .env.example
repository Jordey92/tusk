# Preferred: full connection string
DATABASE_URL=postgresql://user:password@localhost:5432/app

# Alternative: individual settings
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=app
# DB_USER=postgres
# DB_PASSWORD=secret

# Optional
# MIGRATIONS_PATH=./migrations
# LOG_LEVEL=info
# TUSK_DRIVER=pg
# TUSK_STATEMENT_TIMEOUT_MS=300000
